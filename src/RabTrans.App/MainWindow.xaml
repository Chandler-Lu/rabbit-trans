<Window
    x:Class="RabTrans.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
    Title="RabTrans"
    Icon="Assets/RabTransIcon.ico"
    Width="380" Height="390"
    MinWidth="380" MinHeight="390"
    MaxHeight="820"
    WindowStartupLocation="CenterScreen"
    WindowStyle="None"
    ResizeMode="CanResizeWithGrip"
    KeyDown="MainWindow_KeyDown"
    Background="{StaticResource BackgroundBrush}">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome
            CaptionHeight="30"
            ResizeBorderThickness="6"
            GlassFrameThickness="0"
            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Background="{StaticResource BackgroundBrush}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="30"/>
                <RowDefinition Height="48"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="28"/>
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Grid Grid.Row="0" Background="{StaticResource SurfaceBrush}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="RabTrans"
                           Style="{StaticResource TitleTextStyle}"
                           Margin="12,0,0,0"
                           VerticalAlignment="Center"/>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,6,0"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button x:Name="PinWindowButton"
                            Content="&#xE718;"
                            Style="{StaticResource IconButtonStyle}"
                            ToolTip="Pin window"
                            Click="PinWindowButton_Click"/>
                    <Button x:Name="HideOnDeactivateButton"
                            Content="&#xE890;"
                            Style="{StaticResource IconButtonStyle}"
                            ToolTip="Hide when window loses focus"
                            Click="HideOnDeactivateButton_Click"/>
                    <Button x:Name="MinimizeButton"
                            Content="&#xE921;"
                            Style="{StaticResource IconButtonStyle}"
                            ToolTip="Minimize"
                            Click="MinimizeButton_Click"/>
                    <Button x:Name="MaximizeButton"
                            Content="&#xE922;"
                            Style="{StaticResource IconButtonStyle}"
                            ToolTip="Maximize"
                            Click="MaximizeButton_Click"/>
                    <Button x:Name="CloseButton"
                            Content="&#xE8BB;"
                            Style="{StaticResource IconButtonStyle}"
                            ToolTip="Hide to tray"
                            Click="CloseButton_Click"/>
                </StackPanel>
            </Grid>

            <!-- Mode and language toolbar -->
            <Grid Grid.Row="1" Margin="12,7,12,7">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="&#xE8B3;"
                            Style="{StaticResource ToolbarButtonStyle}"
                            ToolTip="Screenshot OCR"
                            Click="OcrButton_Click"/>
                    <Button Content="&#xE77F;"
                            Style="{StaticResource ToolbarButtonStyle}"
                            Margin="6,0,0,0"
                            ToolTip="Paste from clipboard"
                            Click="PasteButton_Click"/>
                    <Button Content="&#xE81C;"
                            Style="{StaticResource ToolbarButtonStyle}"
                            Margin="6,0,0,0"
                            ToolTip="History"
                            Click="HistoryButton_Click"/>
                    <Button Content="&#xE713;"
                            Style="{StaticResource ToolbarButtonStyle}"
                            Margin="6,0,0,0"
                            ToolTip="Settings"
                            Click="SettingsButton_Click"/>
                </StackPanel>

                <Grid Grid.Column="1" Margin="12,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <ComboBox x:Name="SourceLanguageCombo"
                              Grid.Column="0"
                              SelectionChanged="Language_SelectionChanged">
                        <ComboBoxItem Content="Auto Detect" Tag="auto" IsSelected="True"/>
                        <ComboBoxItem Content="English" Tag="en"/>
                        <ComboBoxItem Content="Chinese" Tag="zh-CN"/>
                        <ComboBoxItem Content="Japanese" Tag="ja"/>
                        <ComboBoxItem Content="Korean" Tag="ko"/>
                    </ComboBox>

                    <Button Grid.Column="1"
                            Content="&#xE8AB;"
                            Style="{StaticResource IconButtonStyle}"
                            Width="32"
                            Margin="6,0"
                            ToolTip="Swap languages"
                            Click="SwapLanguages_Click"/>

                    <ComboBox x:Name="TargetLanguageCombo"
                              Grid.Column="2"
                              SelectionChanged="Language_SelectionChanged">
                        <ComboBoxItem Content="English" Tag="en"/>
                        <ComboBoxItem Content="Chinese" Tag="zh-CN" IsSelected="True"/>
                        <ComboBoxItem Content="Japanese" Tag="ja"/>
                        <ComboBoxItem Content="Korean" Tag="ko"/>
                    </ComboBox>
                </Grid>

                <Button x:Name="TranslateButton"
                        Grid.Column="2"
                        Content="Go"
                        Style="{StaticResource PrimaryButtonStyle}"
                        MinWidth="54"
                        Click="TranslateButton_Click"/>
            </Grid>

            <!-- Translation panes -->
            <Grid Grid.Row="2" Margin="12,0,12,0">
                <Grid.RowDefinitions>
                    <RowDefinition x:Name="SourcePaneRow" Height="128"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition x:Name="ResultPaneRow" Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Background="{StaticResource SurfaceBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="14">
                    <TextBox x:Name="SourceTextBox"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"
                             TextChanged="SourceText_TextChanged"/>
                </Border>

                <Border Grid.Row="2"
                        Background="{StaticResource SurfaceBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="14"
                        ClipToBounds="True">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Result" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" FontWeight="SemiBold"/>
                        </Grid>

                        <Grid x:Name="ResultScrollHost" Grid.Row="1" ClipToBounds="True">
                            <TextBox x:Name="TranslatedTextBox"
                                     Visibility="Collapsed"
                                     TextWrapping="Wrap"
                                     IsReadOnly="True"/>

                            <ScrollViewer x:Name="ResultScrollViewer"
                                          VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled"
                                          CanContentScroll="False"
                                          Padding="0"
                                          Margin="0">
                                <ItemsControl x:Name="TranslationResultsList">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="{StaticResource BorderBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="6"
                                                    Padding="10"
                                                    Margin="0,0,0,8">
                                                <StackPanel>
                                                    <Grid Margin="0,0,0,6">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="{Binding ProviderName}"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                                                        <TextBlock Grid.Column="1"
                                                                   Text="{Binding StatusText}"
                                                                   Foreground="{Binding StatusBrush}"
                                                                   FontSize="12"
                                                                   VerticalAlignment="Center"/>
                                                        <Button Grid.Column="2"
                                                                Content="&#xE8C8;"
                                                                Style="{StaticResource IconButtonStyle}"
                                                                Width="24"
                                                                Height="22"
                                                                Margin="8,0,0,0"
                                                                ToolTip="Copy this result"
                                                                Tag="{Binding Text}"
                                                                Click="CopySingleResultButton_Click"/>
                                                    </Grid>
                                                    <TextBlock Text="{Binding Text}"
                                                               Foreground="{StaticResource TextPrimaryBrush}"
                                                               TextWrapping="Wrap"
                                                               FontSize="14"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>

            <!-- Status Bar -->
            <Grid Grid.Row="3" Margin="12,0,12,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Ellipse Grid.Column="0" Width="6" Height="6" Fill="{StaticResource AccentBrush}" VerticalAlignment="Center"/>
                <TextBlock x:Name="StatusText"
                           Grid.Column="1"
                           Text="Ready"
                           Margin="7,0,0,0"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="11"/>
            </Grid>
        </Grid>
    </Border>
</Window>
