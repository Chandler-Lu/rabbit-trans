<Window
    x:Class="RabTrans.ScreenshotSelectionWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    WindowStyle="None"
    AllowsTransparency="True"
    Background="#22000000"
    Topmost="True"
    ShowInTaskbar="False"
    WindowState="Maximized"
    Cursor="Cross"
    KeyDown="Window_KeyDown"
    MouseDown="Window_MouseDown"
    MouseMove="Window_MouseMove"
    MouseUp="Window_MouseUp">

    <Canvas x:Name="SelectionCanvas">
        <Rectangle x:Name="SelectionRectangle"
                   Stroke="#3D7EFF"
                   StrokeThickness="2"
                   Fill="#223D7EFF"
                   Visibility="Collapsed"/>
        <Border x:Name="Hint"
                Canvas.Left="24"
                Canvas.Top="24"
                Background="#E620242C"
                CornerRadius="6"
                Padding="12,8">
            <TextBlock Text="Drag to select OCR area. Press Esc to cancel."
                       Foreground="White"
                       FontSize="13"/>
        </Border>
    </Canvas>
</Window>
